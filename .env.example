# ====== LINE Messaging API (สำหรับ Bot) ======
# ดูได้ที่ LINE Developers Console > Messaging API Channel > Messaging API
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token_here
LINE_CHANNEL_SECRET=your_channel_secret_here

# ====== LINE Login / LIFF (สำหรับหน้าเว็บกรอกคะแนน) ======
# ดูได้ที่ LINE Developers Console > LINE Login Channel > Basic settings > Channel ID
LIFF_CHANNEL_ID=your_liff_login_channel_id_here

# LIFF ID จากหน้า LIFF tab (จะได้หลังสร้าง LIFF app)
# รูปแบบเช่น 1234567890-abcdefgh
LIFF_ID=your_liff_id_here

# ====== Server ======
PORT=3000
